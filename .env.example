# Скопируйте в .env в корне репозитория для docker compose
POSTGRES_USER=jobtrack
POSTGRES_PASSWORD=jobtrack
POSTGRES_DB=jobtrack
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1,http://127.0.0.1:80,http://localhost:5173,http://127.0.0.1:5173
RUN_SEED=true
LOG_LEVEL=INFO
